meta {
  name: DataStoreContexts - Not Found
  type: http
  seq: 16
}

put {
  url: {{API_URL}}/v3/dataStoreContexts/{{NotExistDataStoresContextId}}
  body: json
  auth: inherit
}

body:json {
  {
    "dataStoreId": {{DataStoreId}},
    "contextKey": "ckey3",
    "contextValue": "cvalue3"
  }
}

script:post-response {
  test("PUT DataStoreContexts NotFound: Status code is Not Found", function () {
      expect(res.getStatus()).to.equal(404);
  });
  
  test("PUT DataStoreContexts NotFound: Response matches error format", function () {
      const response = res.getBody();
  
      expect(response).to.have.property("title");
  });
  
  test("PUT DataStoreContexts NotFound: Response title is helpful and accurate", function () {
      const response = res.getBody();
  
      expect(response.title).to.contain("Not found");
      expect(response.title).to.contain("DataStoreContext");
      expect(response.title).to.contain(bru.getEnvVar("NotExistDataStoresContextId"));
  });
  
}

settings {
  encodeUrl: true
}
