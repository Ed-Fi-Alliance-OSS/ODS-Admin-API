meta {
  name: Applications
  type: http
  seq: 24
}

delete {
  url: {{API_URL}}/v3/applications/{{CreatedApplicationId}}
  body: none
  auth: inherit
}

script:post-response {
  test("DELETE Applications: Status code is No Content", function () {
      expect(res.getStatus()).to.equal(204);
  });

  const response = res.getBody();
  const Ajv = require('ajv');
  const ajv = new Ajv();
  const DeleteApplicationsSchema = {
    oneOf: [
      { type: "null" },
      { type: "string", maxLength: 0 }
    ]
  };
  
  test("DELETE Applications: Validation Schema Response", () => {
      const valid = ajv.validate(DeleteApplicationsSchema, response);
      expect(valid).to.be.true;
      
      if (!valid) {
          console.log("Schema validation errors:", ajv.errors);
      }
  });
}

settings {
  encodeUrl: true
}
