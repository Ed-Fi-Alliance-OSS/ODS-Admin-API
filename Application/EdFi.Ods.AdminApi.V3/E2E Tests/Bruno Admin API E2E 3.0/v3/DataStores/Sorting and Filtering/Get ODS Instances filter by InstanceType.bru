meta {
  name: Get DataStores filter by dataStoreType
  type: http
  seq: 10
}

get {
  url: {{API_URL}}/v3/dataStores?offset={{offset}}&limit={{limit}}&dataStoreType={{FILTERdataStoreType}}
  body: json
  auth: inherit
}

params:query {
  offset: {{offset}}
  limit: {{limit}}
  dataStoreType: {{FILTERdataStoreType}}
}

script:pre-request {
  try {
    if (typeof process !== 'undefined' && process.env) {
      process.env.NODE_TLS_REJECT_UNAUTHORIZED = '0';
    }
  } catch (e) {}

  const axios = require('axios');
  const API_URL = bru.getEnvVar("API_URL");
  const TOKEN = bru.getEnvVar("TOKEN");
  const axiosConfig = {
    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${TOKEN}` },
    validateStatus: (status) => status < 500,
    timeout: 30000
  };
  if (bru.getEnvVar("isMultitenant") == "true") {
    axiosConfig.headers['Tenant'] = bru.getEnvVar("tenant1");
  }

  try {
    const timestamp = Date.now();
    const dsType = `filter-type-${timestamp}`;
    const res = await axios.post(`${API_URL}/v3/dataStores`, {
      "name": `FilterDS-Type-${timestamp}`,
      "dataStoreType": dsType,
      "connectionString": bru.getEnvVar("connectionString")
    }, axiosConfig);

    if (res.status === 201) {
      bru.setVar("FILTERdataStoreType", dsType);
      const id = parseInt(res.headers.location.split("/").pop(), 10);
      bru.setVar("FilterTypeDS_ID", id);
      console.log(`✅ Filter-by-Type DataStore created with type: ${dsType}`);
    } else {
      console.log(`❌ Failed to create filter DataStore: ${res.status}`, JSON.stringify(res.data));
    }
  } catch (error) {
    console.log("Error in filter-by-type pre-request:", error.message);
  }
}

script:post-response {
  test("GET DataStores: Status code is OK", function () {
      expect(res.getStatus()).to.equal(200);
  });
  
  test("GET DataStores: Response result includes DataStore", function () {
      const results = res.getBody();
      expect(results).to.have.lengthOf(1);
  });
  
  test("GET DataStores: Response result contains requested DataStore", function () {
      const results = res.getBody();
      expect(results[0].dataStoreType).to.eql(String(bru.getVar("FILTERdataStoreType")));
  });

  // Cleanup the DataStore created in pre-request
  try {
    if (typeof process !== 'undefined' && process.env) {
      process.env.NODE_TLS_REJECT_UNAUTHORIZED = '0';
    }
  } catch (e) {}

  const axios = require('axios');
  const API_URL = bru.getEnvVar("API_URL");
  const TOKEN = bru.getEnvVar("TOKEN");
  const axiosConfig = {
    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${TOKEN}` },
    validateStatus: (status) => status < 500,
    timeout: 30000
  };
  if (bru.getEnvVar("isMultitenant") == "true") {
    axiosConfig.headers['Tenant'] = bru.getEnvVar("tenant1");
  }
  const id = bru.getVar("FilterTypeDS_ID");
  if (id) {
    (async () => {
      try {
        await axios.delete(`${API_URL}/v3/dataStores/${id}`, axiosConfig);
        console.log(`✅ Cleaned up filter-by-type DataStore ${id}`);
      } catch (e) {
        console.log(`❌ Cleanup failed for DataStore ${id}:`, e.message);
      }
    })();
  }
}

settings {
  encodeUrl: true
}
