meta {
  name: Get ODS Instances filter by dataStoreType
  type: http
  seq: 10
}

get {
  url: {{API_URL}}/v3/dataStores?offset={{offset}}&limit={{limit}}&dataStoreType={{FILTERdataStoreType}}
  body: json
  auth: inherit
}

params:query {
  offset: {{offset}}
  limit: {{limit}}
  dataStoreType: {{FILTERdataStoreType}}
}

script:post-response {
  test("GET Ods Instances: Status code is OK", function () {
      expect(res.getStatus()).to.equal(200);
  });
  
  test("GET Ods Instances: Response result includes Ods Instance", function () {
      const results = res.getBody();
      expect(results).to.have.lengthOf(1);
  });
  
  test("GET Ods Instances: Response result contains requested Ods Instance", function () {
      const results = res.getBody();
      expect(results[0].dataStoreType).to.eql(String(bru.getEnvVar("FILTERdataStoreType")));
  });
  
}

settings {
  encodeUrl: true
}
