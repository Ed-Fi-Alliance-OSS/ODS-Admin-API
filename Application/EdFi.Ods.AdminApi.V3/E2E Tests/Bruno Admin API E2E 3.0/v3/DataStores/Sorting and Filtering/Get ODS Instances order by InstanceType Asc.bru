meta {
  name: Get DataStores order by dataStoreType Asc
  type: http
  seq: 7
}

get {
  url: {{API_URL}}/v3/dataStores?offset={{offset}}&limit={{limit}}&orderBy=dataStoreType&direction=ASC
  body: json
  auth: inherit
}

params:query {
  offset: {{offset}}
  limit: {{limit}}
  orderBy: dataStoreType
  direction: ASC
}

script:post-response {
  var _ = require('lodash');
  
  test("GET DataStores: Status code is OK", function () {
      expect(res.getStatus()).to.equal(200);
  });
  
  test("GET DataStores: Response result includes DataStores", function () {
      const results = res.getBody();
      expect(results.length).to.be.greaterThan(0);   
  });
  
  test("GET DataStores: Response result is ordered by dataStoreType asc", function () {
      const results = res.getBody();
      var expectedSortedOrder = _.orderBy(results, [DataStore => DataStore.dataStoreType ? DataStore.dataStoreType : null],['asc']);
      expect(results).to.eql(expectedSortedOrder);
  });
  
}

settings {
  encodeUrl: true
}
