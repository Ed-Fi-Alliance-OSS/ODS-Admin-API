meta {
  name: Get DataStores order by Id Asc
  type: http
  seq: 3
}

get {
  url: {{API_URL}}/v3/dataStores?offset={{offset}}&limit={{limit}}&orderBy=id&direction=ASC
  body: json
  auth: inherit
}

params:query {
  offset: {{offset}}
  limit: {{limit}}
  orderBy: id
  direction: ASC
}

script:post-response {
  var _ = require('lodash');
  
  test("GET DataStores: Status code is OK", function () {
      expect(res.getStatus()).to.equal(200);
  });
  
  test("GET DataStores: Response result includes DataStores", function () {
      const results = res.getBody();
      expect(results.length).to.be.greaterThan(0);   
  });
  
  test("GET DataStores: Response result is ordered by Id asc", function () {
      const results = res.getBody();
      var expectedSortedOrder = _.orderBy(results, [DataStore => DataStore.id],['asc']);
      
      expect(results).to.eql(expectedSortedOrder);
  });
  
}

settings {
  encodeUrl: true
}
