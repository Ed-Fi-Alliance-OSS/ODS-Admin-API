meta {
  name: DataStores
  type: http
  seq: 14
}

put {
  url: {{API_URL}}/v3/dataStores/{{CreatedDataStoreId}}
  body: json
  auth: inherit
}

body:json {
  {
      "name": "Updated-Test-DataStore-{{DataStoreGUID}}",
      "dataStoreType": "Updated-Test-OdsdataStoreType",
      "connectionString": "{{connectionString}}"
  
  }
}

script:post-response {
  test("PUT DataStore: Status code is No Content", function () {
      expect(res.getStatus()).to.equal(204);
  });
  
  console.log("🔧 Setting post environment to ignore SSL certificates...");
  // Safely set Node.js environment variable if available (CLI only)
  try {
    if (typeof process !== 'undefined' && process.env) {
      process.env.NODE_TLS_REJECT_UNAUTHORIZED = '0';
    }
  } catch (e) {
    // Ignore in UI environment
  }
  
  const axios = require('axios');
  const API_URL = bru.getEnvVar("API_URL");
  const TOKEN = bru.getEnvVar("TOKEN");

  // Configure axios to handle SSL and network issues
  const axiosConfig = {
    headers: {
      'Content-Type': 'application/json',
      'Authorization': `Bearer ${TOKEN}`
    },
    validateStatus: function (status) {
      return status < 500;
    },
    timeout: 30000
  };

  // Add tenant header if multitenant mode is enabled
  if (bru.getEnvVar("isMultitenant") == "true") {
    axiosConfig.headers['Tenant'] = `${bru.getEnvVar("tenant1")}`;
  }

  try {
    const createdOdsId = bru.getVar("CreatedDataStoreId");
    const odsResponse = await axios.get(`${API_URL}/v3/dataStores/${createdOdsId}`, axiosConfig);

    if (odsResponse.status === 200) {
      console.log("✅ DataStore List loaded");
      const updatedDataStoreJson = odsResponse.data;
      test("PUT DataStore: Response includes updated DataStore", function () {
        expect(updatedDataStoreJson.name).to.equal(`Updated-Test-DataStore-${bru.getVar("DataStoreGUID")}`);
        expect(updatedDataStoreJson.dataStoreType).to.not.be.empty;
       });
    } else {
      console.log("❌ Failed to get DataStores");
      console.log("Status:", odsResponse.status);
      console.log("Response data:", JSON.stringify(odsResponse.data, null, 2));
      throw new Error(`Failed to get DataStores - Status: ${odsResponse.status}, Data: ${JSON.stringify(odsResponse.data)}`);
    }    
  } catch (error) {
    console.log("Error in post-request setup:", error.message);
  }  
}

settings {
  encodeUrl: true
}
