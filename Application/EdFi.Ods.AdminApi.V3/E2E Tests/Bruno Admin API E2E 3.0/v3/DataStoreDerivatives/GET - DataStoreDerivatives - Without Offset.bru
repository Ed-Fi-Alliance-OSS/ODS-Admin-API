meta {
  name: DataStoreDerivatives - Without Offset
  type: http
  seq: 13
}

get {
  url: {{API_URL}}/v3/dataStoreDerivatives/?limit={{limit}}
  body: none
  auth: inherit
}

params:query {
  limit: {{limit}}
}

script:post-response {
  test("GET DataStoreDerivatives: Status code is OK", function () {
      expect(res.getStatus()).to.equal(200);
  });
  
  test("GET DataStoreDerivatives: Response result includes DataStoresDerivative", function () {
      const results = res.getBody();
      expect(results.length).to.be.greaterThan(0);   
  });
  
  const response = res.getBody();
  const Ajv = require('ajv');
  const ajv = new Ajv();
  const GetDataStoreDerivativesSchema = {
    "type": "array",
    "items": [
      {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer"
          },
          "derivativeType": {
            "type": "string"
          },
          "connectionString": {
            "type": "string"
          },
          "dataStoreId": {
            "type": "integer"
          },
        },
        "required": [
          "id",
          "derivativeType",
          "dataStoreId"     
        ]
      }
    ]
  }
  
  test("GET DataStoreDerivatives: Validation Schema Response", () => {
      const valid = ajv.validate(GetDataStoreDerivativesSchema, response);
      expect(valid).to.be.true;
      
      if (!valid) {
          console.log("Schema validation errors:", ajv.errors);
      }
  });
  
}

settings {
  encodeUrl: true
}
