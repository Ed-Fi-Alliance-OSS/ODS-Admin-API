meta {
  name: DataStoreDerivatives - ID Mismatch
  type: http
  seq: 25
}

put {
  url: {{API_URL}}/v3/dataStoreDerivatives/{{CreatedDataStoreDerivativeId}}
  body: json
  auth: inherit
}

body:json {
  {
    "id": 999999,
    "dataStoreId": {{DataStoreId}},
    "derivativeType": "ReadReplica",
    "connectionString": "{{connectionString}}"
  }
}

script:post-response {
  test("PUT DataStoreDerivatives ID Mismatch: Status code is Bad Request", function () {
      expect(res.getStatus()).to.equal(400);
  });
  
  const response = res.getBody();
  
  test("PUT DataStoreDerivatives ID Mismatch: Response matches error format", function () {
      expect(response).to.have.property("title");
      expect(response).to.have.property("errors");
  });
  
  test("PUT DataStoreDerivatives ID Mismatch: Response includes Id mismatch error", function () {
      expect(response.errors["Id"].length).to.equal(1);
      expect(response.errors["Id"][0]).to.contain("must match the ID in the URL");
  });
}

settings {
  encodeUrl: true
}
