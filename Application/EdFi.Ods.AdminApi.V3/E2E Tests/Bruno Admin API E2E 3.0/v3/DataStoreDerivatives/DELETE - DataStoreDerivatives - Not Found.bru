meta {
  name: DataStoreDerivatives - Not Found
  type: http
  seq: 27
}

delete {
  url: {{API_URL}}/v3/dataStoreDerivatives/{{NotExistDataStoresDerivativeId}}
  body: none
  auth: inherit
}

script:post-response {
  test("DELETE DataStoreDerivatives NotFound: Status code is Not Found", function () {
      expect(res.getStatus()).to.equal(404);
  });
  
  test("DELETE DataStoreDerivatives NotFound: Response matches error format", function () {
      const response = res.getBody();
  
      expect(response).to.have.property("title");
  });
  
  test("DELETE DataStoreDerivatives NotFound: Response title is helpful and accurate", function () {
      const response = res.getBody();
  
      expect(response.title).to.contain("Not found");
      expect(response.title).to.contain("DataStoreDerivative");
      expect(response.title).to.contain(bru.getEnvVar("NotExistDataStoresDerivativeId"));
  });
}

settings {
  encodeUrl: true
}
