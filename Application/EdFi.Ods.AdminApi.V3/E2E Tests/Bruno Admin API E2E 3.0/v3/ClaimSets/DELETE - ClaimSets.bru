meta {
  name: ClaimSets
  type: http
  seq: 52
}

delete {
  url: {{API_URL}}/v3/claimSets/{{CreatedClaimSetId}}
  body: none
  auth: inherit
}

script:post-response {
  test("DELETE ClaimSets: Status code is No Content", function () {
      expect(res.getStatus()).to.equal(204);
  });

  const response = res.getBody();
  const Ajv = require('ajv');
  const ajv = new Ajv();
  const DeleteClaimSetsSchema = {
    oneOf: [
      { type: "null" },
      { type: "string", maxLength: 0 }
    ]
  };
  
  test("DELETE ClaimSet: JSON Schema Validation", () => {
      const valid = ajv.validate(DeleteClaimSetsSchema, response);
      expect(valid).to.be.true;
      
      if (!valid) {
          console.log("Schema validation errors:", ajv.errors);
      }
  });
  
}

settings {
  encodeUrl: true
}
