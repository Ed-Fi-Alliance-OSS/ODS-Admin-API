<Project>
    <!-- This file is generated by the build script. -->
    <PropertyGroup>
        <Product>Ed-Fi ODS Admin API</Product>
        <Authors>Ed-Fi Alliance, LLC and contributors</Authors>
        <Company>Ed-Fi Alliance, LLC and contributors</Company>
        <Copyright>Copyright ©  Ed-Fi Alliance</Copyright>
        <VersionPrefix>0.1</VersionPrefix>
        <VersionSuffix></VersionSuffix>
    </PropertyGroup>
    <ItemGroup>
        <!-- packages.lock.json must not be published: Microsoft.NET.Sdk.Web picks up *.json
             as Content by default, and having the lock file from multiple projects land at
             the same relative output path triggers NETSDK1152. -->
        <Content Remove="packages.lock.json" />
    </ItemGroup>
</Project>
